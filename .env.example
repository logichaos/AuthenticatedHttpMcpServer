# ──────────────────────────────────────────────────────────
# AuthenticatedHttpMcpServer — .env template
# ──────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.
# ──────────────────────────────────────────────────────────

# ── Entra ID (Azure AD) ───────────────────────────────────
# Required if Mcp:OAuth:Schemes:EntraId:Enabled is true

Mcp__OAuth__Schemes__EntraId__TenantId=
Mcp__OAuth__Schemes__EntraId__ClientId=

# Optional overrides:
# Mcp__OAuth__Schemes__EntraId__Audience=api://your-client-id
# Mcp__OAuth__Schemes__EntraId__Instance=https://login.microsoftonline.com/

# ── Auth0 ─────────────────────────────────────────────────
# Required if Mcp:OAuth:Schemes:Auth0:Enabled is true

# Mcp__OAuth__Schemes__Auth0__Domain=your-tenant.auth0.com
# Mcp__OAuth__Schemes__Auth0__ClientId=your-auth0-client-id

# ── InMemory (local dev) ──────────────────────────────────
# Point to the TestOAuthServer included in the repo:
# Mcp__OAuth__Schemes__InMemory__AuthorityUrl=https://localhost:7029

# ── Misc ──────────────────────────────────────────────────
# Mcp__OAuth__ServerUrl=https://mcp.example.com
# Mcp__OAuth__ResourceDocumentation=https://docs.example.com/mcp-api
