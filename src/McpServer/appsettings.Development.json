{
  "Mcp": {
    "OAuth": {
      "DefaultScheme": "InMemory",
      "ServerUrl": "http://localhost:7071/",
      "Schemes": {
        "InMemory": {
          "Enabled": true,
          "DisableBackchannelSslValidation": true
        },
        "EntraId": {
          "Enabled": false
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Debug"
    },
    "Console": {
      "LogLevel": {
        "Default": "Debug",
        "Microsoft.AspNetCore": "Debug"
      }
    }
  },
  "RateLimiterOptions": {
    "Enabled": true,
    "FixedWindowRateLimit": {
      "AutoReplenishment": true,
      "PermitLimit": 10,
      "Window": "00:01:00"
    },
    "McpWindowRateLimit": {
      "AutoReplenishment": true,
      "PermitLimit": 30,
      "Window": "00:01:00"
    }
  }  
}
