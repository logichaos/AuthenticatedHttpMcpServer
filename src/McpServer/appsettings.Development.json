{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft.AspNetCore": "Debug"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/app.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 3,
          "fileSizeLimitBytes": 10485760
        }
      }
    ]
  },
  "RateLimiterOptions": {
    "FixedWindowRateLimit": {
      "AutoReplenishment": true,
      "PermitLimit": 10,
      "Window": "00:01:00"
    },
    "McpWindowRateLimit": {
      "AutoReplenishment": true,
      "PermitLimit": 30,
      "Window": "00:01:00"
    }
  }  
}
